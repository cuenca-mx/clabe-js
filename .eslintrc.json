{
    "parserOptions": {
        "ecmaVersion": 2020,
        "sourceType": "module",
        "ecmaFeatures": {
            "jsx": true
        }
    },
    "env": {
        "browser": true,
        "amd": true,
        "node": true,
        "es2020": true,
        "mocha": true
    },
    "extends": [
        "eslint:recommended"
    ],
    "rules": {
      "semi": [1, "always"],
      "indent": ["error", 2],
      "object-curly-spacing": ["error", "always"],
      "no-extra-parens": "error",
      "max-len": ["error", { "code": 100 }],
      "no-multi-spaces": "error",
      "space-infix-ops": ["error"]
    }
}
